# Copy to .env.local and fill in (never commit .env.local).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Use either legacy anon JWT OR new publishable key (dashboard) — not both required.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable__YOUR_KEY

# Resend — new order notification emails (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxx
# Optional: recipient (defaults to app constant if unset)
# ORDER_NOTIFICATION_EMAIL=you@example.com
# Optional: verified sender after domain setup (defaults to Resend test sender)
# RESEND_FROM=Stree <orders@yourdomain.com>
