NEXT_PUBLIC_SUPABASE_URL=
# Use either ANON_KEY or PUBLISHABLE_DEFAULT_KEY (Supabase dashboard)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Brevo SMTP — order notification emails (https://app.brevo.com → SMTP & API)
# Defaults: host smtp-relay.brevo.com, port 587
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_PASSWORD=

# Inbox for new-order alerts
ORDER_NOTIFICATION_EMAIL=info@streesarees.com

# Must match a sender verified in Brevo (Senders / domain)
SMTP_FROM=Stree Orders <info@streesarees.com>
